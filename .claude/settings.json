{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd backend && python *)",
      "Bash(cd frontend && npm *)",
      "Bash(uvicorn *)",
      "Bash(pip install *)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Bash(*GEMINI_API_KEY*)",
      "Bash(*API_KEY*)",
      "Bash(echo $GEMINI*)"
    ]
  }
}
